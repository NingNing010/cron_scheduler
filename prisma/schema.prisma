generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id             Int      @id @default(autoincrement())
  name           String
  cronExpression String
  nextRun        DateTime?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
}
